generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  pending
  queued
  running
  blocked
  failed
  completed
  cancelled
}

enum EventSeverity {
  info
  warning
  critical
}

model Agent {
  id              String      @id @default(cuid())
  slug            String      @unique
  displayName     String
  workspacePath   String
  openclawBinding String
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tasks           Task[]
  logs            TaskLog[]
  runs            TaskRun[]
}

model Campaign {
  id            String      @id @default(cuid())
  name          String
  description   String?
  owner         String?
  status        String      @default("active")
  priority      Int         @default(3)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tasks         Task[]
  events        SystemEvent[]
}

model Task {
  id              String      @id @default(cuid())
  campaignId      String
  agentId         String
  title           String
  description     String
  payload         Json
  priority        Int         @default(3)
  status          TaskStatus  @default(pending)
  scheduledFor    DateTime?
  retries         Int         @default(0)
  maxRetries      Int         @default(2)
  dependsOnTaskId String?
  blockedReason   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  queuedAt        DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  campaign        Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  agent           Agent       @relation(fields: [agentId], references: [id])
  dependsOn       Task?       @relation("TaskDependencies", fields: [dependsOnTaskId], references: [id])
  dependents      Task[]      @relation("TaskDependencies")
  logs            TaskLog[]
  runs            TaskRun[]
}

model TaskRun {
  id             String      @id @default(cuid())
  taskId         String
  agentId        String
  status         TaskStatus
  output         String?
  errorMessage   String?
  openclawRunId  String?
  durationMs     Int?
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?
  task           Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent          Agent       @relation(fields: [agentId], references: [id])
}

model TaskLog {
  id          String      @id @default(cuid())
  taskId       String
  agentId      String
  level        String
  message      String
  meta         Json?
  createdAt    DateTime    @default(now())
  task         Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent        Agent       @relation(fields: [agentId], references: [id])
}

model SystemEvent {
  id           String        @id @default(cuid())
  type         String
  severity     EventSeverity @default(info)
  message      String
  campaignId   String?
  taskId       String?
  metadata     Json?
  createdAt    DateTime      @default(now())
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}
